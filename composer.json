{
    "name": "spyrit/doctrine-datagrid-bundle",
    "description": "Symfony Datagrid Bundle for Doctrine.",
    "keywords": ["datagrid", "symfony", "doctrine"],
    "homepage": "https://github.com/spyrit/DoctrineDatagridBundle.git",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxime Corson",
            "email": "maxime.corson@spyrit.net",
            "role": "Developer"
        },
        {
            "name": "Charles Henzel",
            "email": "charles.henzel@spyrit.net",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "support@spyrit.net"
    },
    "require": {
        "php": "^8.2",
        "csanquer/colibri-csv": "1.2.*",
        "doctrine/orm": "^2.0",
        "symfony/form": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/config": "^7.0",
        "symfony/http-kernel": "^7.0",
        "webmozart/assert": "^2.1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
	    "psr-4": { "Spyrit\\Bundle\\DoctrineDatagridBundle\\": "" }
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
